@page "/mcpservers"
@using AiDemo.Models
@using AiDemo.Services
@inject ConfigurationService ConfigService
@rendermode InteractiveServer

<PageTitle>MCP Server</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><span class="bi bi-hdd-stack me-2"></span>MCP Server Verwaltung</h3>
        <button class="btn btn-primary" @onclick="AddNewServer">
            + Neuer Server
        </button>
    </div>

    @if (_servers.Count == 0)
    {
        <div class="alert alert-info">
            Keine MCP Server konfiguriert. Klicken Sie auf "Neuer Server" um einen hinzuzufügen.
        </div>
    }

    @foreach (var server in _servers)
    {
        <div class="card mb-3 @(server.Enabled ? "" : "opacity-50")">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <div class="form-check form-switch me-3">
                        <input class="form-check-input" type="checkbox" checked="@server.Enabled"
                               @onchange="e => ToggleServer(server, (bool)(e.Value ?? false))" />
                    </div>
                    @if (_editingServerId == server.Id)
                    {
                        <input class="form-control form-control-sm" style="width: 250px"
                               @bind="server.Name" />
                    }
                    else
                    {
                        <h5 class="mb-0">🖥️ @server.Name</h5>
                    }
                </div>
                <div>
                    @if (_editingServerId == server.Id)
                    {
                        <button class="btn btn-sm btn-success me-1" @onclick="() => SaveServer(server)">Speichern</button>
                        <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">Abbrechen</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditServer(server)">Bearbeiten</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveServer(server.Id)">Löschen</button>
                    }
                </div>
            </div>

            <div class="card-body">
                @if (_editingServerId == server.Id)
                {
                    <div class="mb-3">
                        <label class="form-label">Beschreibung</label>
                        <input class="form-control" @bind="server.Description" />
                    </div>

                    <h6>Tools</h6>
                    @foreach (var tool in server.Tools)
                    {
                        <div class="card mb-2 bg-light">
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="flex-grow-1 me-2">
                                        <div class="mb-2">
                                            <label class="form-label small mb-0">Tool-Name</label>
                                            <input class="form-control form-control-sm" @bind="tool.Name" />
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label small mb-0">Beschreibung</label>
                                            <input class="form-control form-control-sm" @bind="tool.Description" />
                                        </div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveTool(server, tool)">×</button>
                                </div>

                                <div class="mb-1">
                                    <label class="form-label small mb-0">Parameter</label>
                                </div>
                                @foreach (var param in tool.Parameters.ToList())
                                {
                                    <div class="row g-1 mb-1 align-items-center">
                                        <div class="col-3">
                                            <input class="form-control form-control-sm" value="@param.Key" disabled />
                                        </div>
                                        <div class="col-2">
                                            <select class="form-select form-select-sm" @bind="param.Value.Type">
                                                <option value="string">string</option>
                                                <option value="number">number</option>
                                                <option value="boolean">boolean</option>
                                            </select>
                                        </div>
                                        <div class="col-4">
                                            <input class="form-control form-control-sm" @bind="param.Value.Description"
                                                   placeholder="Beschreibung" />
                                        </div>
                                        <div class="col-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" @bind="param.Value.Required" />
                                                <label class="form-check-label small">Pflicht</label>
                                            </div>
                                        </div>
                                        <div class="col-1">
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveParameter(tool, param.Key)">×</button>
                                        </div>
                                    </div>
                                }
                                <div class="row g-1 mt-1">
                                    <div class="col-3">
                                        <input class="form-control form-control-sm" @bind="_newParamName" placeholder="Name" />
                                    </div>
                                    <div class="col">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => AddParameter(tool)">
                                            + Parameter
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    <button class="btn btn-sm btn-outline-success" @onclick="() => AddTool(server)">
                        + Neues Tool
                    </button>
                }
                else
                {
                    <p class="text-muted mb-2">@server.Description</p>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var tool in server.Tools)
                        {
                            <div class="badge bg-primary p-2">
                                🔧 @tool.Name
                                <span class="badge bg-light text-dark ms-1">@tool.Parameters.Count Params</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (_savedMessage)
    {
        <div class="alert alert-success">✓ Konfiguration gespeichert.</div>
    }
</div>

@code {
    private List<McpServerConfig> _servers = [];
    private string? _editingServerId;
    private string _newParamName = "";
    private bool _savedMessage;

    protected override void OnInitialized()
    {
        _servers = ConfigService.GetConfig().McpServers;
    }

    private void AddNewServer()
    {
        var server = new McpServerConfig
        {
            Name = "Neuer Server",
            Description = "Beschreibung des Servers",
            Tools = []
        };
        ConfigService.AddMcpServer(server);
        _servers = ConfigService.GetConfig().McpServers;
        _editingServerId = server.Id;
    }

    private void EditServer(McpServerConfig server)
    {
        _editingServerId = server.Id;
    }

    private void CancelEdit()
    {
        _editingServerId = null;
        _servers = ConfigService.GetConfig().McpServers;
    }

    private async Task SaveServer(McpServerConfig server)
    {
        ConfigService.UpdateMcpServer(server);
        _editingServerId = null;
        _savedMessage = true;
        StateHasChanged();
        await Task.Delay(2000);
        _savedMessage = false;
        StateHasChanged();
    }

    private void RemoveServer(string id)
    {
        ConfigService.RemoveMcpServer(id);
        _servers = ConfigService.GetConfig().McpServers;
    }

    private void ToggleServer(McpServerConfig server, bool enabled)
    {
        server.Enabled = enabled;
        ConfigService.UpdateMcpServer(server);
    }

    private void AddTool(McpServerConfig server)
    {
        server.Tools.Add(new McpToolConfig
        {
            Name = "neues_tool",
            Description = "Beschreibung des Tools"
        });
    }

    private void RemoveTool(McpServerConfig server, McpToolConfig tool)
    {
        server.Tools.Remove(tool);
    }

    private void AddParameter(McpToolConfig tool)
    {
        if (string.IsNullOrWhiteSpace(_newParamName)) return;
        tool.Parameters[_newParamName] = new ToolParameter();
        _newParamName = "";
    }

    private void RemoveParameter(McpToolConfig tool, string key)
    {
        tool.Parameters.Remove(key);
    }
}
